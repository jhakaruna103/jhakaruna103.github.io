body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(to right, #ffecd2, #fcb69f);
    color: #333;
}

header {
    background: #ff5722;
    padding: 15px;
    text-align: center;
    color: white;
}

nav {
    background: #ff9800;
    padding: 10px;
    text-align: center;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    color: #000;
}

.container {
    padding: 20px;
}

h1, h2 {
    color: #d84315;
}

.card {
    background: white;
    padding: 15px;
    margin: 15px 0;
    border-radius: 10px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
}

footer {
    background: #ff5722;
    color: white;
    text-align: center;
    padding: 10px;
    margin-top: 20px;
}

button {
    background: #ff5722;
    color: white;
    padding: 10px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

button:hover {
    background: #e64a19;
}

input, textarea {
    width: 100%;
    padding: 10px;
    margin: 8px 0;
}
